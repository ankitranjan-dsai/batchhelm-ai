# ---------------------------------------------------------------------------
# Qwen Cloud / Alibaba Cloud Model Studio (OpenAI-compatible endpoint)
# ---------------------------------------------------------------------------
# Leave QWEN_API_KEY empty to run in deterministic demo-fallback mode (no
# network calls). Set it to a Model Studio key to run the workflow live on Qwen.
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_TEXT_MODEL=qwen-plus
QWEN_VISION_MODEL=qwen-vl-plus
# Per-call request timeout (seconds) and bounded retry attempts on 5xx/transport errors.
QWEN_TIMEOUT_SECONDS=30
QWEN_MAX_RETRIES=2

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=info
# Comma-separated allowed browser origins for CORS.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Fixed-window request cap per client IP per minute (0 disables the limit).
RATE_LIMIT_PER_MINUTE=60
REVIEWER_ROLE=Operations Manager

# Frontend -> backend base URL (Vite).
VITE_API_BASE_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Storage (durable review ledger + agent memory + uploads)
# ---------------------------------------------------------------------------
DATABASE_PATH=./data/batchhelm.db
MEMORY_PATH=./data/batchhelm-memory.db
UPLOAD_DIR=./data/uploads
